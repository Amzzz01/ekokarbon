rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public collections — anyone can read, only authenticated users can write
    match /tips/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /quiz/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /infografik/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
